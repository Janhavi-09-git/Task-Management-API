			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"A\",\n    \"status\": \"UnknownStatus\",\n    \"priority\": \"Critical\",\n    \"due_date\": \"02-07-2026\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/tasks",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"tasks"
					]
				},
				"description": "Expects 422 Unprocessable Entity. Tests validation rules:\n1. Title too short (min=3)\n2. Invalid Status option\n3. Invalid Priority option\n4. Invalid Date Format (must be YYYY-MM-DD)"
