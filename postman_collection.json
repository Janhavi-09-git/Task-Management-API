						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Implement Unit Tests\",\n    \"description\": \"Write endpoint test suites using unittest and WebTest client.\",\n    \"status\": \"Todo\",\n    \"priority\": \"High\",\n    \"due_date\": \"2026-07-02\",\n    \"tags\": [\"testing\", \"quality\"]\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/tasks",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"tasks"
					]
				},
				"description": "Creates a new task. The payload is validated against Marshmallow schema rules before insertion."
			},
			"response": []
		},
